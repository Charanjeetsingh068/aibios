# ==============================================================================
# AI-BOS Enterprise Frontend (Next.js) Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Ports and Host Settings
# ------------------------------------------------------------------------------
# The port Next.js should bind to when running the admin console locally
PORT=3000

# ------------------------------------------------------------------------------
# API Endpoints
# ------------------------------------------------------------------------------
# The path endpoint targeting the FastAPI backend.
# In development, the dev server uses rewrites to forward requests starting with /api to http://localhost:8000.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side (not NEXT_PUBLIC_) backend origin used by next.config.js to build the /api/*
# rewrite proxy. Must be set to the real backend URL in any non-local deployment.
BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Application Environment Mode
# ------------------------------------------------------------------------------
# Operational environment identifier for client validation (development, production)
NEXT_PUBLIC_APP_ENV=development
