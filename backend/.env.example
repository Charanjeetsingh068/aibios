# ==============================================================================
# AI-BOS Enterprise Backend Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Application Configurations
# ------------------------------------------------------------------------------
# The project name used for logs, dashboard titles, and diagnostics
PROJECT_NAME="AI-BOS Enterprise"

# The API path prefix route group for version 1 REST operations
API_V1_STR="/api/v1"

# The security key used for cryptographic JWT payload sign-offs
SECRET_KEY="supersecretchangeinproduction_2026_aibos_token_generation_key"

# Access token timeout restriction limit (11520 minutes = 8 days)
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Operational mode flag defining current environment (development, staging, production)
ENVIRONMENT="development"

# ------------------------------------------------------------------------------
# CORS Origin Routing Configurations
# ------------------------------------------------------------------------------
# A list of comma-separated client URLs authorized to request FastAPI backend data
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081"

# Comma-separated Host header allowlist enforced in production (e.g. "app.example.com,*.example.com").
# Required when ENVIRONMENT=production — leave blank in development.
ALLOWED_HOSTS=""

# Public base URL of the deployed frontend, used to build password-reset/invite links.
FRONTEND_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# Security Roles & Access Control
# ------------------------------------------------------------------------------
# Default role groups assigned across the Role-Based Access Control (RBAC) schemas
DEFAULT_ROLES="administrator,manager,agent,auditor,developer"

# ------------------------------------------------------------------------------
# Production Admin Bootstrap (only used when ENVIRONMENT=production)
# ------------------------------------------------------------------------------
# When ENVIRONMENT=production, the first super-admin account is created from these
# two values (once) instead of the hardcoded local-dev demo account. Leave unset in
# development. If both are unset in production, no admin account is auto-created.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# ------------------------------------------------------------------------------
# PostgreSQL Database Connection Properties
# ------------------------------------------------------------------------------
# Host server location for local PostgreSQL instance (typically localhost)
POSTGRES_SERVER="localhost"

# Communication port of PostgreSQL relational service
POSTGRES_PORT=5432

# DB administrator user credential for PostgreSQL
POSTGRES_USER="aibios_admin"

# DB administrator password credential for PostgreSQL
POSTGRES_PASSWORD="aibios_secure_password_2026"

# Relational schema database name
POSTGRES_DB="aibios_db"

# ------------------------------------------------------------------------------
# MongoDB Database Connection Properties
# ------------------------------------------------------------------------------
# Fully qualified connection URI for the local MongoDB database instance
# Uses 27018 because 27017 may already be bound by another local MongoDB install (see docker-compose.yml)
MONGODB_URL="mongodb://localhost:27018/aibios_nosql"

# ------------------------------------------------------------------------------
# Redis Cache and Broker Connection Properties
# ------------------------------------------------------------------------------
# Host location of the active Redis server instance
REDIS_HOST="localhost"

# Connection port of the active Redis server instance
REDIS_PORT=6379

# Database index used for session caching (typically index 0)
REDIS_DB=0

# Password credential for local Redis instance authentication (empty by default in dev)
REDIS_PASSWORD=""

# ------------------------------------------------------------------------------
# Qdrant Vector Database Connection Properties
# ------------------------------------------------------------------------------
# Host location of the active Qdrant vector database server
QDRANT_HOST="localhost"

# REST API port connection value for Qdrant database server
QDRANT_PORT=6333

# API access security key used for Qdrant (left empty for local developer runs)
QDRANT_API_KEY=""

# ------------------------------------------------------------------------------
# AI Agent Providers Keys (Optional for local bootstrapping phase)
# ------------------------------------------------------------------------------
# OpenAI developer platform API authentication token
OPENAI_API_KEY=""

# Anthropic developer platform API authentication token
ANTHROPIC_API_KEY=""

# Flag enabling system tracing and observability metrics in LangSmith / LangChain
LANGCHAIN_TRACING_V2="false"

# API validation credentials key for LangChain dashboard integration
LANGCHAIN_API_KEY=""

# ------------------------------------------------------------------------------
# OAuth Login Providers (Optional — leave blank to disable that provider)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# ------------------------------------------------------------------------------
# Meta (Facebook / Instagram) Graph API — login OAuth + lead-sync webhook
# ------------------------------------------------------------------------------
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_REDIRECT_URI="http://localhost:3000/auth/callback/facebook"
# Shared secret you choose and also enter in the Meta App's webhook subscription config.
FACEBOOK_WEBHOOK_VERIFY_TOKEN=""

# ------------------------------------------------------------------------------
# WhatsApp Business Cloud API
# ------------------------------------------------------------------------------
WHATSAPP_APP_ID=""
WHATSAPP_APP_SECRET=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
# Shared secret you choose and also enter in Meta's WhatsApp webhook subscription config.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# ------------------------------------------------------------------------------
# Twilio (SMS + Voice)
# ------------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
# Number the IVR transfers callers to when they press 2 for support; leave blank to
# disable that transfer option until you have a real support line.
TWILIO_SUPPORT_NUMBER=""
ELEVENLABS_API_KEY=""

# ------------------------------------------------------------------------------
# AI Voice Platform — additional providers (all optional; leave blank to disable)
# ------------------------------------------------------------------------------
CARTESIA_API_KEY=""
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION=""
GOOGLE_TTS_API_KEY=""

# ------------------------------------------------------------------------------
# Encryption — required before any per-organization integration credential
# (Meta/WhatsApp/voice/n8n OAuth tokens or API keys) can be stored. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Endpoints that would persist a secret fail closed with 503 if this is unset.
# ------------------------------------------------------------------------------
ENCRYPTION_KEY=""

# ------------------------------------------------------------------------------
# n8n Workflow Automation
# ------------------------------------------------------------------------------
# Timeout (seconds) when POSTing to an n8n webhook to trigger a workflow.
N8N_DEFAULT_WEBHOOK_TIMEOUT_SECONDS=15

# ------------------------------------------------------------------------------
# SMTP / Transactional Email (password reset, invites, notifications)
# ------------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_USE_TLS=true
