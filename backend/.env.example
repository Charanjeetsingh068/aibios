# ==============================================================================
# AI-BOS Enterprise Backend Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Application Configurations
# ------------------------------------------------------------------------------
# The project name used for logs, dashboard titles, and diagnostics
PROJECT_NAME="AI-BOS Enterprise"

# The API path prefix route group for version 1 REST operations
API_V1_STR="/api/v1"

# The security key used for cryptographic JWT payload sign-offs
SECRET_KEY="supersecretchangeinproduction_2026_aibos_token_generation_key"

# Access token timeout restriction limit (11520 minutes = 8 days)
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Operational mode flag defining current environment (development, staging, production)
ENVIRONMENT="development"

# ------------------------------------------------------------------------------
# CORS Origin Routing Configurations
# ------------------------------------------------------------------------------
# A list of comma-separated client URLs authorized to request FastAPI backend data
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081"

# ------------------------------------------------------------------------------
# Security Roles & Access Control
# ------------------------------------------------------------------------------
# Default role groups assigned across the Role-Based Access Control (RBAC) schemas
DEFAULT_ROLES="administrator,manager,agent,auditor,developer"

# ------------------------------------------------------------------------------
# PostgreSQL Database Connection Properties
# ------------------------------------------------------------------------------
# Host server location for local PostgreSQL instance (typically localhost)
POSTGRES_SERVER="localhost"

# Communication port of PostgreSQL relational service
POSTGRES_PORT=5432

# DB administrator user credential for PostgreSQL
POSTGRES_USER="aibios_admin"

# DB administrator password credential for PostgreSQL
POSTGRES_PASSWORD="aibios_secure_password_2026"

# Relational schema database name
POSTGRES_DB="aibios_db"

# ------------------------------------------------------------------------------
# MongoDB Database Connection Properties
# ------------------------------------------------------------------------------
# Fully qualified connection URI for the local MongoDB database instance
MONGODB_URL="mongodb://localhost:27017/aibios_nosql"

# ------------------------------------------------------------------------------
# Redis Cache and Broker Connection Properties
# ------------------------------------------------------------------------------
# Host location of the active Redis server instance
REDIS_HOST="localhost"

# Connection port of the active Redis server instance
REDIS_PORT=6379

# Database index used for session caching (typically index 0)
REDIS_DB=0

# Password credential for local Redis instance authentication (empty by default in dev)
REDIS_PASSWORD=""

# ------------------------------------------------------------------------------
# Qdrant Vector Database Connection Properties
# ------------------------------------------------------------------------------
# Host location of the active Qdrant vector database server
QDRANT_HOST="localhost"

# REST API port connection value for Qdrant database server
QDRANT_PORT=6333

# API access security key used for Qdrant (left empty for local developer runs)
QDRANT_API_KEY=""

# ------------------------------------------------------------------------------
# AI Agent Providers Keys (Optional for local bootstrapping phase)
# ------------------------------------------------------------------------------
# OpenAI developer platform API authentication token
OPENAI_API_KEY=""

# Anthropic developer platform API authentication token
ANTHROPIC_API_KEY=""

# Flag enabling system tracing and observability metrics in LangSmith / LangChain
LANGCHAIN_TRACING_V2="false"

# API validation credentials key for LangChain dashboard integration
LANGCHAIN_API_KEY=""
