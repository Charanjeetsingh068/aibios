# ==============================================================================
# AI-BOS Enterprise Mobile (React Native / Expo) Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# API Endpoints
# ------------------------------------------------------------------------------
# The URL pointing to the FastAPI backend API.
# Note: For mobile devices or emulators, you may need to replace 'localhost' with your development machine's local IP address (e.g., http://192.168.1.50:8000/api/v1).
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# ------------------------------------------------------------------------------
# Application Environment Mode
# ------------------------------------------------------------------------------
# Operational environment identifier for client verification (development, production)
EXPO_PUBLIC_APP_ENV=development
