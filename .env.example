# ==============================================================================
# AI-BOS Enterprise Global Environment Variables Template
# ==============================================================================

# ------------------------------------------------------------------------------
# General Settings
# ------------------------------------------------------------------------------
# The operational environment mode (development, staging, production)
ENVIRONMENT=development

# The project/workspace name, used across consoles and client instances
PROJECT_NAME="AI-BOS Enterprise"

# ------------------------------------------------------------------------------
# Backend API Configurations (FastAPI - Port 8000)
# ------------------------------------------------------------------------------
# The local host port binding for the FastAPI REST API gateway server
BACKEND_PORT=8000

# A highly secure, cryptographically random secret string used to sign JWT tokens
SECRET_KEY=generate_a_secure_token_secret_for_jwt_2026_enterprise

# The JWT access token lifespan constraint (11520 minutes = 8 days)
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Production-only admin bootstrap credentials (ignored when ENVIRONMENT=development).
# Leave blank locally; set both before a production deploy to create the first admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ------------------------------------------------------------------------------
# Frontend configurations (Next.js - Port 3000)
# ------------------------------------------------------------------------------
# The local host port binding for the Next.js administration portal console
FRONTEND_PORT=3000

# ------------------------------------------------------------------------------
# Relational Databases (PostgreSQL - Port 5432)
# ------------------------------------------------------------------------------
# The database name used for core transactional tables and metadata schema
POSTGRES_DB=aibios_db

# The administrator username credential for local PostgreSQL instance login
POSTGRES_USER=aibios_admin

# The administrator password credential for local PostgreSQL instance login
POSTGRES_PASSWORD=choose_a_strong_database_password

# The connection port for the PostgreSQL relational server instance
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Document Databases (MongoDB - Port 27017)
# ------------------------------------------------------------------------------
# The full connection URI for the local MongoDB document database engine.
# Note: Host connects directly to 'localhost' for local-first installation.
MONGODB_URL=mongodb://localhost:27017/aibios_nosql

# ------------------------------------------------------------------------------
# Caches & Event Brokers (Redis - Port 6379)
# ------------------------------------------------------------------------------
# The connection port for the Redis ephemeral token cache and session broker
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Vector Store / Episodic Memory (Qdrant - Port 6333)
# ------------------------------------------------------------------------------
# The HTTP REST API endpoint connection port for the Qdrant vector database
QDRANT_PORT=6333

# The gRPC high-performance endpoint communication port for Qdrant client library calls
QDRANT_GRPC_PORT=6334
